{
  "$schema": "./node_modules/wrangler/config-schema.json",
  "name": "spectramuse",
  "compatibility_date": "2026-06-23",
  "workers_dev": true,
  "assets": {
    "directory": "./dist",
    "not_found_handling": "single-page-application"
  },
  "routes": [
    {
      "pattern": "spectramuse.com/*",
      "zone_name": "spectramuse.com"
    },
    {
      "pattern": "www.spectramuse.com/*",
      "zone_name": "spectramuse.com"
    }
  ]
}
